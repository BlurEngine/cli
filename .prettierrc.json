{
  "tabWidth": 2,
  "useTabs": false,
  "endOfLine": "lf",
  "singleQuote": false,
  "trailingComma": "all",
  "overrides": [
    {
      "files": ["*.js", "*.cjs", "*.mjs", "*.ts", "*.cts", "*.mts"],
      "options": {
        "tabWidth": 4
      }
    },
    {
      "files": ["*.json", "*.jsonc", "*.yml", "*.yaml"],
      "options": {
        "tabWidth": 2
      }
    }
  ]
}
